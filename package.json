{
  "name": "cardscentral",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo/metro-runtime": "~56.0.16",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.18.0",
    "@react-navigation/native": "^7.3.1",
    "@react-navigation/native-stack": "^7.17.3",
    "expo": "~56.0.11",
    "expo-camera": "^56.0.8",
    "expo-image-picker": "^56.0.17",
    "expo-status-bar": "~56.0.4",
    "js-yaml": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/react-native": "^14.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "~19.2.2",
    "detox": "^20.51.3",
    "jest": "~29.7.0",
    "jest-circus": "^30.4.2",
    "simple-icons": "^16.23.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "node scripts/build-web.js",
    "serve:web": "node scripts/serve-web.js",
    "e2e:web": "playwright test",
    "e2e:web:ui": "playwright test --ui",
    "e2e:web:report": "playwright show-report",
    "generate:shops": "node scripts/generate-shops.js",
    "generate:icon": "node scripts/generate-icon.js",
    "generate:landing": "node scripts/generate-landing-screens.js",

    "typecheck": "npm run generate:shops && npm run generate:icons && npm run fetch:logos && tsc --noEmit",
    "prebuild": "expo prebuild --clean",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "prebuild:android": "expo prebuild --platform android --clean",
    "e2e:build:ios": "detox build --configuration ios.sim.debug",
    "e2e:build:android": "detox build --configuration android.emu.debug",
    "e2e:test:ios": "detox test --configuration ios.sim.debug",
    "e2e:test:android": "detox test --configuration android.emu.debug",
    "generate:icons": "node scripts/generate-brand-icons.js",
    "generate": "npm run generate:shops && npm run generate:icons && npm run fetch:logos",
    "fetch:logos": "node scripts/fetch-logos.js"
  },
  "private": true
}
